# Copy to .env.local and fill in values for GitHub Pages / production deployment.

# Base path — must match your GitHub Pages URL path (e.g. /options-flow-platform/)
# Leave empty for local dev or Docker (served from root)
VITE_BASE=

# FastAPI backend URL — required when deploying frontend separately (GitHub Pages)
# For local dev this is not needed (Vite proxies /api → localhost:8000)
VITE_API_URL=
