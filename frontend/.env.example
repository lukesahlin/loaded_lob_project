# Copy to .env.local and fill in values for GitHub Pages / production deployment.

# Base path — must match your GitHub Pages URL path (e.g. /loaded_lob_project/)
# Leave empty for local dev (served from root)
VITE_BASE=

# FastAPI backend URL — only needed if running the live API instead of static JSON
# Leave unset for local dev or GitHub Pages (static mode)
VITE_API_URL=
